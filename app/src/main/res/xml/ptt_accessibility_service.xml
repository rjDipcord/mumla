<?xml version="1.0" encoding="utf-8"?>
<!--
  Accessibility service configuration for PTTAccessibilityService.
  flagRequestFilterKeyEvents allows the service to intercept hardware key events globally,
  including when the screen is off or another app is in the foreground.
  accessibilityEventTypes is intentionally absent; it is set to 0 in onServiceConnected()
  because this service does not need any UI/window accessibility events.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityFlags="flagRequestFilterKeyEvents"
    android:canRequestFilterKeyEvents="true"
    android:description="@string/ptt_accessibility_description"
    android:notificationTimeout="0"
    android:settingsActivity="se.lublin.mumla.preference.SettingsActivity" />
